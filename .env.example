# Resend API key — server-side only. Required for the Contact app's form to send mail.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Destination address for contact form submissions. Server-side only (no NEXT_PUBLIC prefix
# on purpose — keeps the address out of the client bundle and away from scrapers).
CONTACT_EMAIL=

# Sender address used as the From: header. Must be on a domain you've verified in Resend.
# Resend's docs: https://resend.com/docs/dashboard/domains/introduction
# Format: "Display Name <address@your-verified-domain.com>" or just "address@your-verified-domain.com"
CONTACT_FROM_EMAIL=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Optional.
# When unset, no analytics script loads and trackEvent() is a no-op; the consent
# banner is suppressed (nothing to consent to).
#
# IMPORTANT: NEXT_PUBLIC_* values are inlined into the client bundle at
# `next build` time. Changing this var after a build does NOT change the
# deployed bundle — you must rebuild. If runtime configurability matters,
# expose the id from a server route instead.
#
# Uses NEXT_PUBLIC_ because GA4 runs in the browser; there is no way to
# keep this server-side. This is a deliberate exception to the repo's
# "no NEXT_PUBLIC_*" preference (see AGENTS.md).
NEXT_PUBLIC_GA_ID=